<Window x:Class="BetterCrewLinkKai.DotNet.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterCrewLinkKai Overlay"
        Width="220"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
    <Border x:Name="OverlayPanel"
            Background="#DD1D1A23"
            BorderBrush="#803C3746"
            BorderThickness="1"
            CornerRadius="6"
            Padding="9">
        <StackPanel>
            <Grid x:Name="LocalPlayerPanel" Height="50" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>

                <Grid Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="38"
                             Height="38"
                             Stroke="{Binding LocalRingBrush}"
                             StrokeThickness="{Binding LocalRingThickness}"
                             Fill="#25232A">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#32FF7E"
                                              BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0" />
                        </Ellipse.Effect>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LocalIsTalking}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.9"
                                                                     Duration="0:0:0.25" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="16"
                                                                     Duration="0:0:0.25" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0"
                                                                     Duration="0:0:0.5" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="12"
                                                                     Duration="0:0:0.5" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Grid Width="38" Height="38" ClipToBounds="True">
                        <Grid.Clip>
                            <EllipseGeometry Center="19,19" RadiusX="19" RadiusY="19" />
                        </Grid.Clip>
                        <Viewbox Width="38"
                                 Height="38"
                                 Stretch="Fill">
                            <Grid Width="78" Height="78">
                                <Image Source="{Binding LocalHatBackImage}"
                                       Width="{Binding LocalHatWidth}"
                                       Margin="{Binding LocalHatMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                            <TranslateTransform X="12" Y="-22" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                                <Image Source="{Binding LocalAvatarImage}"
                                       Width="78"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="0" />
                                <Image Source="{Binding LocalSkinImage}"
                                       Width="{Binding LocalSkinWidth}"
                                       Margin="{Binding LocalSkinMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                            <TranslateTransform X="12" Y="-22" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                                <Image Source="{Binding LocalVisorImage}"
                                       Width="{Binding LocalVisorWidth}"
                                       Margin="{Binding LocalVisorMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top" />
                                <Image Source="{Binding LocalHatFrontImage}"
                                       Width="{Binding LocalHatWidth}"
                                       Margin="{Binding LocalHatMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                            <TranslateTransform X="12" Y="-22" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="1" Margin="6,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LocalPlayerName}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <Border Background="#554B4B4B"
                            CornerRadius="3"
                            Padding="5,1"
                            HorizontalAlignment="Left"
                            MinWidth="58">
                        <TextBlock Text="{Binding DisplayLobbyCode}"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Foreground="White"
                                   TextAlignment="Center" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Command="{Binding ToggleMuteCommand}"
                            Style="{StaticResource TitleIconButton}"
                            Width="20"
                            Height="20"
                            ToolTip="Mute microphone">
                        <Viewbox Width="14" Height="14">
                            <Grid Width="24" Height="24">
                                <Path Fill="{Binding IsMuted, Converter={StaticResource MutedIconBrushConverter}}"
                                      Data="M12 14C13.66 14 15 12.66 15 11V5C15 3.34 13.66 2 12 2S9 3.34 9 5V11C9 12.66 10.34 14 12 14ZM17.3 11C17.3 14 14.76 16.1 12 16.1S6.7 14 6.7 11H5C5 14.41 7.72 17.23 11 17.72V21H13V17.72C16.28 17.24 19 14.42 19 11H17.3Z" />
                                <Line X1="5"
                                      Y1="5"
                                      X2="19"
                                      Y2="19"
                                      Stroke="{Binding IsMuted, Converter={StaticResource MutedIconBrushConverter}}"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="{Binding IsMuted, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Viewbox>
                    </Button>
                    <Button Command="{Binding ToggleDeafenCommand}"
                            Style="{StaticResource TitleIconButton}"
                            Width="20"
                            Height="20"
                            ToolTip="Mute speaker">
                        <Viewbox Width="14" Height="14">
                            <Grid Width="24" Height="24">
                                <Path Fill="{Binding IsDeafened, Converter={StaticResource DeafenedIconBrushConverter}}"
                                      Data="M3 9V15H7L12 20V4L7 9H3ZM16.5 12C16.5 10.23 15.5 8.71 14 7.97V16.02C15.48 15.29 16.5 13.76 16.5 12ZM14 3.23V5.29C16.89 6.15 19 8.83 19 12S16.89 17.85 14 18.71V20.77C18.01 19.86 21 16.28 21 12S18.01 4.14 14 3.23Z" />
                                <Line X1="5"
                                      Y1="5"
                                      X2="19"
                                      Y2="19"
                                      Stroke="{Binding IsDeafened, Converter={StaticResource DeafenedIconBrushConverter}}"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="{Binding IsDeafened, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

            <ItemsControl ItemsSource="{Binding OtherPlayers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="48"
                                    Margin="1,2"
                                    HorizontalAlignment="Center"
                                    Opacity="{Binding Opacity}">
                            <StackPanel.ToolTip>
                                <ToolTip>
                                    <Border Background="#1B1820"
                                            BorderBrush="#55505D"
                                            BorderThickness="1"
                                            Padding="8"
                                            Width="180">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Content="ミュート"
                                                          IsChecked="{Binding IsPlayerMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding EffectiveVolumeText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <Slider Minimum="0"
                                                    Maximum="200"
                                                    Value="{Binding VolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0" />
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </StackPanel.ToolTip>
                            <Grid Width="38" Height="38" HorizontalAlignment="Center">
                                <Ellipse Width="34"
                                         Height="34"
                                         Stroke="{Binding RingBrush}"
                                         StrokeThickness="{Binding RingThickness}"
                                         Fill="#25232A"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#32FF7E"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0" />
                                    </Ellipse.Effect>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTalking}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                 To="0.85"
                                                                                 Duration="0:0:0.22" />
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                 To="14"
                                                                                 Duration="0:0:0.22" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                 To="0"
                                                                                 Duration="0:0:0.45" />
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                 To="10"
                                                                                 Duration="0:0:0.45" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <Grid Width="34" Height="34" ClipToBounds="True">
                                    <Grid.Clip>
                                        <EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17" />
                                    </Grid.Clip>
                                    <Viewbox Width="34"
                                             Height="34"
                                             Stretch="Fill">
                                        <Grid Width="38" Height="38">
                                            <Image Source="{Binding HatBackImage}"
                                                   Width="{Binding HatWidth}"
                                                   Margin="{Binding HatMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        <TranslateTransform X="6" Y="-11" />
                                                    </TransformGroup>
                                                </Image.RenderTransform>
                                            </Image>
                                            <Image Source="{Binding AvatarImage}"
                                                   Width="38"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Margin="0" />
                                            <Image Source="{Binding SkinImage}"
                                                   Width="{Binding SkinWidth}"
                                                   Margin="{Binding SkinMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        <TranslateTransform X="6" Y="-11" />
                                                    </TransformGroup>
                                                </Image.RenderTransform>
                                            </Image>
                                            <Image Source="{Binding VisorImage}"
                                                   Width="{Binding VisorWidth}"
                                                   Margin="{Binding VisorMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top" />
                                            <Image Source="{Binding HatFrontImage}"
                                                   Width="{Binding HatWidth}"
                                                   Margin="{Binding HatMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        <TranslateTransform X="6" Y="-11" />
                                                    </TransformGroup>
                                                </Image.RenderTransform>
                                            </Image>
                                        </Grid>
                                    </Viewbox>
                                </Grid>
                                <Border Width="13"
                                        Height="13"
                                        CornerRadius="7"
                                        Background="#DDFF174F"
                                        BorderBrush="White"
                                        BorderThickness="1"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding IsUsingRadio, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Border Width="13"
                                        Height="13"
                                        CornerRadius="7"
                                        Background="#DDCE93D8"
                                        BorderBrush="White"
                                        BorderThickness="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding IsRemoteMuted, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Viewbox Width="9" Height="9">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="White"
                                                  Data="M12 14C13.66 14 15 12.66 15 11V5C15 3.34 13.66 2 12 2S9 3.34 9 5V11C9 12.66 10.34 14 12 14ZM17.3 11C17.3 14 14.76 16.1 12 16.1S6.7 14 6.7 11H5C5 14.41 7.72 17.23 11 17.72V21H13V17.72C16.28 17.24 19 14.42 19 11H17.3ZM19 5L5 19L6.4 20.4L20.4 6.4L19 5Z" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="9"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Width="46" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
