<Window x:Class="BetterCrewLinkKai.DotNet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:BetterCrewLinkKai.DotNet.Models"
        xmlns:vm="clr-namespace:BetterCrewLinkKai.DotNet.ViewModels"
        mc:Ignorable="d"
        Title="BetterCrewLinkKai .NET"
        Height="390"
        MinHeight="390"
        Width="280"
        MinWidth="280"
        Icon="Assets/icon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="{Binding AlwaysOnTop}">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{StaticResource TitleBarBrush}"
              MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource TitleIconButton}"
                    Command="{Binding ToggleSettingsCommand}">
                <Viewbox Width="14" Height="14">
                    <Path Fill="White"
                          Data="M19.43 12.98C19.47 12.66 19.5 12.34 19.5 12S19.47 11.34 19.43 11.02L21.54 9.37C21.73 9.22 21.78 8.95 21.66 8.73L19.66 5.27C19.54 5.05 19.28 4.96 19.05 5.05L16.56 6.05C16.04 5.65 15.5 5.32 14.87 5.07L14.5 2.42C14.46 2.18 14.25 2 14 2H10C9.75 2 9.54 2.18 9.5 2.42L9.13 5.07C8.5 5.32 7.96 5.66 7.44 6.05L4.95 5.05C4.72 4.96 4.46 5.05 4.34 5.27L2.34 8.73C2.21 8.95 2.27 9.22 2.46 9.37L4.57 11.02C4.53 11.34 4.5 11.67 4.5 12S4.53 12.66 4.57 12.98L2.46 14.63C2.27 14.78 2.22 15.05 2.34 15.27L4.34 18.73C4.46 18.95 4.72 19.04 4.95 18.95L7.44 17.95C7.96 18.35 8.5 18.68 9.13 18.93L9.5 21.58C9.54 21.82 9.75 22 10 22H14C14.25 22 14.46 21.82 14.5 21.58L14.87 18.93C15.5 18.68 16.04 18.34 16.56 17.95L19.05 18.95C19.28 19.04 19.54 18.95 19.66 18.73L21.66 15.27C21.78 15.05 21.73 14.78 21.54 14.63L19.43 12.98ZM12 15.5C10.07 15.5 8.5 13.93 8.5 12S10.07 8.5 12 8.5 15.5 10.07 15.5 12 13.93 15.5 12 15.5Z" />
                </Viewbox>
            </Button>
            <Button Grid.Column="1"
                    Style="{StaticResource TitleIconButton}"
                    Command="{Binding LoadCommand}">
                <Viewbox Width="14" Height="14">
                    <Path Fill="White"
                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4C7.58 4 4.01 7.58 4.01 12S7.58 20 12 20C15.73 20 18.84 17.45 19.73 14H17.65C16.83 16.33 14.61 18 12 18C8.69 18 6 15.31 6 12S8.69 6 12 6C13.66 6 15.14 6.69 16.22 7.78L13 11H20V4L17.65 6.35Z" />
                </Viewbox>
            </Button>
            <TextBlock Grid.Column="2"
                       Text="BetterCrewLinkKai v3.1.5-6"
                       Foreground="{StaticResource PrimaryBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0" />
            <Button Grid.Column="3"
                    Style="{StaticResource TitleIconButton}"
                    Command="{Binding CloseCommand}">
                <Viewbox Width="14" Height="14">
                    <Path Fill="White"
                          Data="M18.3 5.71L16.89 4.3 12 9.17 7.11 4.3 5.7 5.71 10.59 10.6 5.7 15.49 7.11 16.9 12 12.01 16.89 16.9 18.3 15.49 13.41 10.6 18.3 5.71Z" />
                </Viewbox>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,36,0,0"
                            Visibility="{Binding ShowWaitingView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding WaitingTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,34" />

                    <Grid Width="22" Height="22" Margin="0,0,0,28">
                        <Canvas Width="22"
                                Height="22"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform />
                            </Canvas.RenderTransform>
                            <Canvas.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(Canvas.RenderTransform).(RotateTransform.Angle)"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:0.85" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Canvas.Triggers>
                            <Ellipse Width="5"
                                     Height="5"
                                     Canvas.Left="8.5"
                                     Canvas.Top="1.5"
                                     Fill="{StaticResource PrimaryBrush}" />
                        </Canvas>
                    </Grid>

                    <TextBlock Text="プリセット"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />

                    <Grid x:Name="LaunchButtonGroup"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{Binding LaunchPlatformLabel}"
                                Grid.Column="0"
                                Command="{Binding LaunchGameCommand}"
                                Style="{StaticResource LaunchButton}"
                                MinWidth="98"
                                Height="54"
                                BorderThickness="4,4,2,4" />
                        <Button Grid.Column="1"
                                Content="v"
                                Command="{Binding ToggleLaunchPlatformMenuCommand}"
                                Style="{StaticResource LaunchDropdownButton}"
                                Height="54"
                                BorderThickness="2,4,4,4" />
                        <Popup Grid.ColumnSpan="2"
                               PlacementTarget="{Binding ElementName=LaunchButtonGroup}"
                               Placement="Bottom"
                               StaysOpen="False"
                               IsOpen="{Binding IsLaunchPlatformMenuOpen}">
                            <Border Background="{StaticResource PaperBrush}"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    MinWidth="{Binding ActualWidth, ElementName=LaunchButtonGroup}">
                                <StackPanel>
                                    <Button Content="Steam"
                                            Command="{Binding SelectLaunchPlatformCommand}"
                                            CommandParameter="{x:Static models:GamePlatform.Steam}"
                                            Style="{StaticResource TitleIconButton}"
                                            Width="150"
                                            Height="32"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,0" />
                                    <Button Content="Epic"
                                            Command="{Binding SelectLaunchPlatformCommand}"
                                            CommandParameter="{x:Static models:GamePlatform.Epic}"
                                            Style="{StaticResource TitleIconButton}"
                                            Width="150"
                                            Height="32"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,0" />
                                    <Button Content="Other"
                                            Command="{Binding SelectLaunchPlatformCommand}"
                                            CommandParameter="{x:Static models:GamePlatform.Microsoft}"
                                            Style="{StaticResource TitleIconButton}"
                                            Width="150"
                                            Height="32"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,0" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <StackPanel Width="250"
                                Margin="0,12,0,0"
                                Visibility="Collapsed">
                        <TextBlock Text="手動接続"
                                   FontSize="13"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding LobbyCode, UpdateSourceTrigger=PropertyChanged}"
                                 CharacterCasing="Upper"
                                 MaxLength="6"
                                 FontFamily="Source Code Pro, Consolas"
                                 FontSize="22"
                                 TextAlignment="Center"
                                 Height="44"
                                 Background="{StaticResource InputBrush}" />
                        <Button Content="{Binding ConnectionButtonText}"
                                Command="{Binding ToggleConnectionCommand}"
                                Style="{StaticResource OutlinedActionButton}"
                                HorizontalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Width="240"
                               Margin="0,16,0,0"
                               Visibility="Collapsed" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,36,0,0"
                            Visibility="{Binding ShowMenuView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="メニュー"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                    <Separator Width="280"
                               Background="#333139"
                               Margin="-12,0,-12,10" />
                    <Button Content="公開ロビー"
                            Style="{StaticResource OutlinedActionButton}"
                            Command="{Binding OpenPublicLobbyBrowserCommand}"
                            HorizontalAlignment="Center"
                            MinWidth="104"
                            Margin="0,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,8,0,0"
                            Visibility="{Binding ShowVoiceView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid Width="236" Height="92">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid Width="78"
                                  Height="78"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False">
                                <Ellipse Width="78"
                                         Height="78"
                                         Stroke="{Binding LocalRingBrush}"
                                         StrokeThickness="{Binding LocalRingThickness}"
                                         Fill="#25232A">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#32FF7E"
                                                          BlurRadius="16"
                                                          ShadowDepth="0"
                                                          Opacity="0" />
                                    </Ellipse.Effect>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LocalIsTalking}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                 To="0.9"
                                                                                 Duration="0:0:0.28" />
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                 To="20"
                                                                                 Duration="0:0:0.28" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                 To="0"
                                                                                 Duration="0:0:0.55" />
                                                                <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                 To="16"
                                                                                 Duration="0:0:0.55" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <Grid Width="78"
                                      Height="78"
                                      ClipToBounds="True">
                                    <Grid.Clip>
                                        <EllipseGeometry Center="39,39" RadiusX="39" RadiusY="39" />
                                    </Grid.Clip>
                                    <Image Source="{Binding LocalHatBackImage}"
                                           Width="{Binding LocalHatWidth}"
                                           Margin="{Binding LocalHatMargin}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="2" ScaleY="2" />
                                                <TranslateTransform X="12" Y="-22" />
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                    </Image>
                                    <Image Source="{Binding LocalAvatarImage}"
                                           Width="78"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           Margin="0" />
                                    <Image Source="{Binding LocalSkinImage}"
                                           Width="{Binding LocalSkinWidth}"
                                           Margin="{Binding LocalSkinMargin}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="2" ScaleY="2" />
                                                <TranslateTransform X="12" Y="-22" />
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                    </Image>
                                </Grid>
                                <Image Source="{Binding LocalVisorImage}"
                                       Width="{Binding LocalVisorWidth}"
                                       Margin="{Binding LocalVisorMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top" />
                                <Image Source="{Binding LocalHatFrontImage}"
                                       Width="{Binding LocalHatWidth}"
                                       Margin="{Binding LocalHatMargin}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                            <TranslateTransform X="12" Y="-22" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,0,0,0">
                            <TextBlock Text="{Binding LocalPlayerName}"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6" />
                            <Border Background="#4B4B4B"
                                    CornerRadius="4"
                                    Padding="6,4"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="{Binding DisplayLobbyCode}"
                                           FontFamily="Source Code Pro, Consolas"
                                           FontSize="24"
                                           Foreground="White"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Button Command="{Binding ToggleMuteCommand}"
                                    Style="{StaticResource TitleIconButton}"
                                    Width="24"
                                    Height="24"
                                    ToolTip="マイクミュート">
                                <Viewbox Width="18"
                                         Height="18"
                                         HorizontalAlignment="Center">
                                    <Grid Width="24" Height="24">
                                        <Path Fill="{Binding IsMuted, Converter={StaticResource MutedIconBrushConverter}}"
                                              Data="M12 14C13.66 14 15 12.66 15 11V5C15 3.34 13.66 2 12 2S9 3.34 9 5V11C9 12.66 10.34 14 12 14ZM17.3 11C17.3 14 14.76 16.1 12 16.1S6.7 14 6.7 11H5C5 14.41 7.72 17.23 11 17.72V21H13V17.72C16.28 17.24 19 14.42 19 11H17.3Z" />
                                        <Line X1="5"
                                              Y1="5"
                                              X2="19"
                                              Y2="19"
                                              Stroke="{Binding IsMuted, Converter={StaticResource MutedIconBrushConverter}}"
                                              StrokeThickness="2.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="{Binding IsMuted, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding ToggleDeafenCommand}"
                                    Style="{StaticResource TitleIconButton}"
                                    Width="24"
                                    Height="24"
                                    ToolTip="スピーカーミュート">
                                <Viewbox Width="18"
                                         Height="18"
                                         HorizontalAlignment="Center">
                                    <Grid Width="24" Height="24">
                                        <Path Fill="{Binding IsDeafened, Converter={StaticResource DeafenedIconBrushConverter}}"
                                              Data="M3 9V15H7L12 20V4L7 9H3ZM16.5 12C16.5 10.23 15.5 8.71 14 7.97V16.02C15.48 15.29 16.5 13.76 16.5 12ZM14 3.23V5.29C16.89 6.15 19 8.83 19 12S16.89 17.85 14 18.71V20.77C18.01 19.86 21 16.28 21 12S18.01 4.14 14 3.23Z" />
                                        <Line X1="5"
                                              Y1="5"
                                              X2="19"
                                              Y2="19"
                                              Stroke="{Binding IsDeafened, Converter={StaticResource DeafenedIconBrushConverter}}"
                                              StrokeThickness="2.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="{Binding IsDeafened, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Separator Width="280" Background="#333139" Margin="-12,0,-12,0" />

                    <ItemsControl ItemsSource="{Binding OtherPlayers}"
                                  Width="240"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="56"
                                            Margin="2"
                                            HorizontalAlignment="Center"
                                            Opacity="{Binding Opacity}">
                                    <StackPanel.ToolTip>
                                        <ToolTip>
                                            <Border Background="#1B1820"
                                                    BorderBrush="#55505D"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Width="180">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,6" />
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Content="ミュート"
                                                                  IsChecked="{Binding IsPlayerMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Margin="0" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding EffectiveVolumeText}"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <Slider Minimum="0"
                                                            Maximum="200"
                                                            Value="{Binding VolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Margin="0" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </StackPanel.ToolTip>
                                    <Grid Width="44" Height="44" HorizontalAlignment="Center">
                                        <Grid Width="38"
                                              Height="38"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ClipToBounds="False">
                                            <Ellipse Width="38"
                                                     Height="38"
                                                     Stroke="{Binding RingBrush}"
                                                     StrokeThickness="{Binding RingThickness}"
                                                     Fill="#25232A">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#32FF7E"
                                                                      BlurRadius="12"
                                                                      ShadowDepth="0"
                                                                      Opacity="0" />
                                                </Ellipse.Effect>
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTalking}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                             To="0.85"
                                                                                             Duration="0:0:0.25" />
                                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                             To="16"
                                                                                             Duration="0:0:0.25" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                             To="0"
                                                                                             Duration="0:0:0.5" />
                                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                             To="12"
                                                                                             Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Grid Width="38"
                                                  Height="38"
                                                  ClipToBounds="True">
                                                <Grid.Clip>
                                                    <EllipseGeometry Center="19,19" RadiusX="19" RadiusY="19" />
                                                </Grid.Clip>
                                                <Image Source="{Binding HatBackImage}"
                                                       Width="{Binding HatWidth}"
                                                       Margin="{Binding HatMargin}"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                                            <TranslateTransform X="6" Y="-11" />
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>
                                                <Image Source="{Binding AvatarImage}"
                                                       Width="38"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       Margin="0" />
                                                <Image Source="{Binding SkinImage}"
                                                       Width="{Binding SkinWidth}"
                                                       Margin="{Binding SkinMargin}"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       RenderTransformOrigin="0.5,0.5">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="2" ScaleY="2" />
                                                            <TranslateTransform X="6" Y="-11" />
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>
                                            </Grid>
                                            <Image Source="{Binding VisorImage}"
                                                   Width="{Binding VisorWidth}"
                                                   Margin="{Binding VisorMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top" />
                                            <Image Source="{Binding HatFrontImage}"
                                                   Width="{Binding HatWidth}"
                                                   Margin="{Binding HatMargin}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="2" ScaleY="2" />
                                                        <TranslateTransform X="6" Y="-11" />
                                                    </TransformGroup>
                                                </Image.RenderTransform>
                                            </Image>
                                            <Border Width="16"
                                                    Height="16"
                                                    CornerRadius="8"
                                                    Background="#DDFF174F"
                                                    BorderBrush="White"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="-2,-2,0,0"
                                                    Visibility="{Binding IsUsingRadio, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Viewbox Width="11" Height="11">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="White"
                                                              Data="M4 7.5C4 5.57 5.57 4 7.5 4H14C17.31 4 20 6.69 20 10V17.5C20 18.88 18.88 20 17.5 20H10C6.69 20 4 17.31 4 14V7.5ZM7.5 6C6.67 6 6 6.67 6 7.5V14C6 16.21 7.79 18 10 18H17.5C17.78 18 18 17.78 18 17.5V10C18 7.79 16.21 6 14 6H7.5ZM8 8H13V10H8V8ZM8 12H16V14H8V12Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <Border Width="16"
                                                    Height="16"
                                                    CornerRadius="8"
                                                    Background="#DDCE93D8"
                                                    BorderBrush="White"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-2,-2,0"
