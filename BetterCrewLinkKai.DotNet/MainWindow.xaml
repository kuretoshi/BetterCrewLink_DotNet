                </Grid>
            </Grid>

            <Border Background="#EE1B1A20"
                    Padding="12,0,0,0"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="設定"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Content="←"
                                Command="{Binding ToggleSettingsCommand}"
                                Style="{StaticResource TitleIconButton}"
                                Width="34"
                                Height="34"
                                FontSize="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0"
                                  Margin="0,0,-2,0">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SettingsScrollBar}" />
                        </ScrollViewer.Resources>
                        <StackPanel Margin="0,0,12,0">
                            <Separator Background="#333139" Margin="0,0,0,12" />

                            <TextBlock Text="ロビー設定"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LobbySettingsModeText}"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,4" />
                            <StackPanel IsEnabled="{Binding CanChangeLobbySettings}">
                                <TextBlock Text="{Binding EffectiveMaxDistance, StringFormat=ボイスの距離: {0:0.0}}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,2" />
                                <Slider Minimum="0.5"
                                        Maximum="20"
                                        Value="{Binding EffectiveMaxDistance}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="ロビーを公開する" IsChecked="{Binding EffectivePublicLobbyOn}" />
                                <Button Content="ロビー情報の変更"
                                        IsEnabled="{Binding EffectivePublicLobbyOn}"
                                        Command="{Binding OpenPublicLobbySettingsCommand}"
                                        Style="{StaticResource OutlinedActionButton}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,8" />
                                <CheckBox Content="壁越しで音声をブロック" IsChecked="{Binding EffectiveWallsBlockAudio}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="視野内のプレイヤーの声だけが聞こえる" IsChecked="{Binding EffectiveVisionHearing}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="インポスターが幽霊の声も聞こえる" IsChecked="{Binding EffectiveHaunting}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="第三陣営が幽霊の声も聞こえる" IsChecked="{Binding EffectiveThirdPartyHaunting}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="ボイスエフェクトを有効化" IsChecked="{Binding EffectiveVoiceEffectEnabled}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="インポスターはベント内にいても声が聞こえる" IsChecked="{Binding EffectiveHearImpostorsInVents}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="インポスター同士でベント内で会話ができる" IsChecked="{Binding EffectiveImpostorsHearImpostorsInVent}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="コミュサボタージュで音声を無効化" IsChecked="{Binding EffectiveCommsSabotage}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="カメラ越しに声が聞こえる" IsChecked="{Binding EffectiveHearThroughCameras}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="インポスターラジオ" IsChecked="{Binding EffectiveImpostorRadioEnabled}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="幽霊だけが話す/聞くことが可能" IsChecked="{Binding EffectiveDeadOnly}" />
                                <Separator Background="#333139" />
                                <CheckBox Content="ミーティング/ロビーのみ" IsChecked="{Binding EffectiveMeetingGhostOnly}" />
                            </StackPanel>

                            <TextBlock Text="オーディオ"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,22,0,10" />
                            <TextBlock Text="マイク" Foreground="{StaticResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding Microphones}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedMicrophone, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False"
                                      MaxDropDownHeight="180" />
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Height="8"
                                         Value="{Binding MicrophoneLevel, Mode=OneWay}"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         Background="#3A3840"
                                         Margin="24,2,24,14" />
                            <TextBlock Text="スピーカー" Foreground="{StaticResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding Speakers}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedSpeaker, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False"
                                      MaxDropDownHeight="180" />
                            <Button Content="スピーカーテスト"
                                    Command="{Binding TestSpeakerCommand}"
                                    Style="{StaticResource HotPinkButton}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,12" />
                            <TextBlock Text="ボイスエフェクトの強さ"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <Slider Minimum="0" Maximum="200" Value="{Binding VoiceEffectStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="{Binding VoiceEffectTestButtonText}"
                                    Command="{Binding TestVoiceEffectCommand}"
                                    Style="{StaticResource HotPinkButton}"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,12" />
                            <RadioButton Content="常に有効"
                                         GroupName="PushMode"
                                         IsChecked="{Binding SelectedPushToTalkMode, Mode=TwoWay, Converter={StaticResource EnumBooleanConverter}, ConverterParameter={x:Static models:PushToTalkMode.Voice}}" />
                            <RadioButton Content="押して話す"
                                         GroupName="PushMode"
                                         IsChecked="{Binding SelectedPushToTalkMode, Mode=TwoWay, Converter={StaticResource EnumBooleanConverter}, ConverterParameter={x:Static models:PushToTalkMode.PushToTalk}}" />
                            <RadioButton Content="押してミュート"
                                         GroupName="PushMode"
                                         IsChecked="{Binding SelectedPushToTalkMode, Mode=TwoWay, Converter={StaticResource EnumBooleanConverter}, ConverterParameter={x:Static models:PushToTalkMode.PushToMute}}" />
                            <Separator Background="#333139" />
                            <TextBlock Text="マイク音量" Margin="0,8,0,0" />
                            <CheckBox Content="" IsChecked="{Binding MicrophoneGainEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Slider Minimum="0" Maximum="200" Value="{Binding MicrophoneGain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="マイク感度" />
                            <CheckBox Content="" IsChecked="{Binding MicSensitivityEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Slider Minimum="0" Maximum="1" Value="{Binding MicSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Separator Background="#333139" />
                            <TextBlock Text="マスターボリューム" Margin="0,8,0,0" />
                            <Slider Minimum="0" Maximum="200" Value="{Binding MasterVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="幽霊クルーの音量" />
                            <Slider Minimum="0" Maximum="200" Value="{Binding CrewVolumeAsGhost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="インポスター時の幽霊の音量" />
                            <Slider Minimum="0" Maximum="200" Value="{Binding GhostVolumeAsImpostor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="キーボードショートカット"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="押して話す" Foreground="{StaticResource SubtleTextBrush}" />
                                    <TextBox Text="{Binding Settings.PushToTalkShortcut, UpdateSourceTrigger=PropertyChanged}"
                                             Tag="PushToTalkShortcut"
                                             PreviewKeyDown="OnShortcutPreviewKeyDown"
                                             PreviewMouseDown="OnShortcutPreviewMouseDown" />
                                    <TextBlock Text="ミュート" Foreground="{StaticResource SubtleTextBrush}" />
                                    <TextBox Text="{Binding Settings.MuteShortcut, UpdateSourceTrigger=PropertyChanged}"
                                             Tag="MuteShortcut"
                                             PreviewKeyDown="OnShortcutPreviewKeyDown"
                                             PreviewMouseDown="OnShortcutPreviewMouseDown" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="インポスターラジオ" Foreground="{StaticResource SubtleTextBrush}" />
                                    <TextBox Text="{Binding Settings.ImpostorRadioShortcut, UpdateSourceTrigger=PropertyChanged}"
                                             Tag="ImpostorRadioShortcut"
                                             PreviewKeyDown="OnShortcutPreviewKeyDown"
                                             PreviewMouseDown="OnShortcutPreviewMouseDown" />
                                    <TextBlock Text="スピーカーミュート" Foreground="{StaticResource SubtleTextBrush}" />
                                    <TextBox Text="{Binding Settings.DeafenShortcut, UpdateSourceTrigger=PropertyChanged}"
                                             Tag="DeafenShortcut"
                                             PreviewKeyDown="OnShortcutPreviewKeyDown"
                                             PreviewMouseDown="OnShortcutPreviewMouseDown" />
                                </StackPanel>
                            </Grid>
                            <Separator Background="#333139" />

                            <TextBlock Text="オーバーレイ"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,14,0,8" />
                            <CheckBox Content="最前面に表示" IsChecked="{Binding AlwaysOnTop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="オーバーレイを有効化" IsChecked="{Binding EnableOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="コンパクトなオーバーレイ" IsChecked="{Binding CompactOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="議論のオーバーレイ表示" IsChecked="{Binding MeetingOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="オーバーレイの位置" Foreground="{StaticResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding OverlayPositionOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding OverlayPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False" />

                            <TextBlock Text="詳細設定"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,8" />
                            <CheckBox Content="NATの修正" IsChecked="{Binding NatFix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="ボイスサーバーの変更"
                                    Style="{StaticResource HotPinkButton}"
                                    Command="{Binding OpenVoiceServerSettingsCommand}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,12" />

                            <TextBlock Text="ベータ/デバッグ"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,8" />
                            <CheckBox Content="モバイルホスト" IsChecked="{Binding MobileHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="音声アクティビティ検出" IsChecked="{Binding VadEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="ハードウェア アクセラレーション" IsChecked="{Binding HardwareAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="エコーキャンセラー" IsChecked="{Binding EchoCancellation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="立体音響" IsChecked="{Binding EnableSpatialAudio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="ノイズ防止" IsChecked="{Binding NoiseSuppression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="サンプルレートデバッグ" IsChecked="{Binding OldSampleDebug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding VoiceCaptureStatus}"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding PeerConnectionStatus}"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="言語" Foreground="{StaticResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Language, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="False" />

                            <TextBlock Text="配信設定"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,8" />
                            <CheckBox Content="ロビーコードを隠す" IsChecked="{Binding HideCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="OBS ブラウザーのオーバーレイ" IsChecked="{Binding ObsOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding ObsOverlayStatus}"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,-2,0,6" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <Button Content="URLコピー"
                                        Command="{Binding CopyObsOverlayUrlCommand}"
                                        Style="{StaticResource OutlinedActionButton}"
                                        Padding="10,5"
                                        Margin="0,0,8,0" />
                                <Button Content="URL再生成"
                                        Command="{Binding RegenerateObsSecretCommand}"
                                        Style="{StaticResource OutlinedActionButton}"
                                        Padding="10,5" />
                            </StackPanel>

                            <TextBlock Text="トラブルシューティング"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,8" />
                            <Button Content="デフォルトに戻す"
                                    Style="{StaticResource HotPinkButton}"
                                    Command="{Binding ResetSettingsCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,22" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Background="#F51B1A20"
                    Padding="12,0,12,0"
                    Visibility="{Binding IsVoiceServerSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="ボイスサーバーの変更"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Content="←"
                                Command="{Binding CloseVoiceServerSettingsCommand}"
                                Style="{StaticResource TitleIconButton}"
                                Width="34"
                                Height="34"
                                FontSize="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="保存済みボイスサーバー" Foreground="{StaticResource SubtleTextBrush}" />
                        <ComboBox ItemsSource="{Binding VoiceServerUrls}"
                                  SelectedValue="{Binding SelectedVoiceServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="False" />
                        <TextBlock Text="ボイスサーバー" Foreground="{StaticResource SubtleTextBrush}" />
                        <TextBox Text="{Binding VoiceServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                 SpellCheck.IsEnabled="False" />
                        <TextBlock Text="URL が正しくありません。例: https://bettercrewl.ink または bettercrewl.ink"
                                   Foreground="#FF6B8A"
                                   TextWrapping="Wrap"
                                   Margin="0,-8,0,8"
                                   Visibility="{Binding IsVoiceServerUrlValid, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <Border Background="#3A2030"
                                BorderBrush="#FF174F"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,10">
                            <TextBlock Text="信頼できるボイスサーバーだけを使ってください。サーバーを変更するとボイス接続を張り直します。"
                                       TextWrapping="Wrap"
                                       Foreground="White" />
                        </Border>
                        <Button Content="デフォルトに戻す"
                                Command="{Binding ResetVoiceServerCommand}"
                                Style="{StaticResource HotPinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8" />
                        <Button Content="このサーバーを削除"
                                Command="{Binding RemoveVoiceServerCommand}"
                                IsEnabled="{Binding CanRemoveVoiceServer}"
                                Style="{StaticResource OutlinedActionButton}"
                                HorizontalAlignment="Left" />
                    </StackPanel>

                    <Grid Grid.Row="2"
                          Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="キャンセル"
                                Command="{Binding CloseVoiceServerSettingsCommand}"
                                Style="{StaticResource OutlinedActionButton}"
                                HorizontalAlignment="Left" />
                        <Button Grid.Column="3"
                                Content="追加/保存"
                                Command="{Binding SaveVoiceServerSettingsCommand}"
                                IsEnabled="{Binding IsVoiceServerUrlValid}"
                                Style="{StaticResource HotPinkButton}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Background="#F51B1A20"
                    Padding="12,0,12,0"
                    Visibility="{Binding IsPublicLobbyBrowserOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="公開ロビー"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Content="←"
                                Command="{Binding ClosePublicLobbyBrowserCommand}"
                                Style="{StaticResource TitleIconButton}"
                                Width="34"
                                Height="34"
                                FontSize="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding PublicLobbyBrowserMessage}"
                               Foreground="{StaticResource SubtleTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,8" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PublicLobbies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#3B3842"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,8,2" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PlayersText}"
                                                       FontFamily="Source Code Pro, Consolas"
                                                       Foreground="{StaticResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding Host, StringFormat=Host: {0}}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Grid Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ModsText}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding LanguageText, StringFormat={}{0}}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SubtleTextBrush}" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SubtleTextBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="コード"
                                                        Command="{Binding DataContext.RequestPublicLobbyCodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanShowCode}"
                                                        Style="{StaticResource OutlinedActionButton}"
                                                        Padding="10,5"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Background="#F51B1A20"
                    Padding="12,0,12,0"
                    Visibility="{Binding IsPublicLobbySettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="ロビー情報の変更"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Content="←"
                                Command="{Binding ClosePublicLobbySettingsCommand}"
                                Style="{StaticResource TitleIconButton}"
                                Width="34"
                                Height="34"
                                FontSize="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="タイトル" Foreground="{StaticResource SubtleTextBrush}" />
                        <TextBox Text="{Binding PublicLobbyTitle, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="40"
                                 SpellCheck.IsEnabled="False" />
                        <TextBlock Text="言語" Foreground="{StaticResource SubtleTextBrush}" />
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding PublicLobbyLanguage, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="False" />
                        <TextBlock Text="MOD" Foreground="{StaticResource SubtleTextBrush}" />
                        <ComboBox ItemsSource="{Binding ModOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding PublicLobbyMods, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="False" />
                        <Border Background="#3A2030"
                                BorderBrush="#FF174F"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,8,0,0">
                            <TextBlock Text="公開ロビーにすると、参加者にロビー情報が表示されます。迷惑行為につながる内容は入れないでください。"
                                       TextWrapping="Wrap"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="2"
                            Content="OK"
                            Command="{Binding ClosePublicLobbySettingsCommand}"
                            Style="{StaticResource HotPinkButton}"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,14" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>


